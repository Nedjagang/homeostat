# Copy to .env (git-ignored) and fill in real values. Never commit .env.

# LLM provider: Azure OpenAI via its OpenAI-compatible v1 surface (no dated
# api-version needed). Required for the agent's answers and (later) the Tier-2 judge.
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com/
# Deployment name, NOT a model family string. Named AZURE_OPENAI_DEPLOYMENT rather than
# MODEL: Windows env vars are case-insensitive and some OEM laptops ship "Model=<number>",
# which silently wins because load_dotenv() never overrides existing process vars.
AZURE_OPENAI_DEPLOYMENT=REPLACE_ME_DEPLOYMENT_NAME
# Optional: the weaker deployment the v_overconfident chaos release downgrades to.
# Strong models resist an overconfident prompt and keep abstaining; the regression is
# reproducible when the release swaps prompt AND model together (like a real
# cost-cutting release would). Empty = same model as above.
CHAOS_OVERCONFIDENT_MODEL=

# Where the agent exports OTLP (traces + metrics + logs).
# - Agent on the host, local collector:    http://localhost:4318
# - Agent dockerized on `signoz-network`:  http://signoz-ingester:4318 (set by docker-compose.apps.yaml)
# - Remote SigNoz ingester (dev VM):       https://<host>/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Bearer token required by the mutating /control endpoints (the heal surface repoints
# the live prompt — do not run it open outside local dev). The brain uses the same
# value to authenticate its remediation calls. Empty = auth disabled.
CLAIMPILOT_CONTROL_TOKEN=REPLACE_ME_LONG_RANDOM_STRING

# Seconds between claims in the continuous loop (jittered ±50%). Lower = denser
# dashboards = more LLM spend.
CLAIM_INTERVAL_SECONDS=20

# Wired up with the brain + alerting — placeholders until then.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/TOKEN
SIGNOZ_API_KEY=REPLACE_ME
CLAIMPILOT_CONTROL_URL=http://localhost:8091
