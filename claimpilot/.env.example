# Copy to .env (git-ignored) and fill in real values. Never commit .env.

# LLM provider: Azure OpenAI. Required for the agent's answer generation and (later)
# the Tier-2 judge.
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com/
MODEL=REPLACE_ME_DEPLOYMENT_NAME
# Azure requires a dated api-version — check the Azure AI Foundry portal for the exact
# value your deployment needs.
OPENAI_API_VERSION=2024-10-21

# Where the agent exports OTLP. Point at the collector, never straight at SigNoz.
# - Running the agent on the host (not dockerized): http://localhost:4318
# - Running the agent as a container on the `signoz-network` (see docker-compose.yaml): http://signoz-ingester:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Wired up on Thursday (brain + alerting) — placeholders for now.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/TOKEN
SIGNOZ_API_KEY=REPLACE_ME
CLAIMPILOT_CONTROL_URL=http://localhost:8091
