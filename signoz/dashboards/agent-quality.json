{
  "schemaVersion": "v6",
  "name": "claimpilot-agent-quality",
  "tags": [
    {
      "key": "project",
      "value": "homeostat"
    },
    {
      "key": "service",
      "value": "claimpilot"
    },
    {
      "key": "type",
      "value": "agent-quality"
    }
  ],
  "spec": {
    "display": {
      "name": "ClaimPilot — Agent Quality",
      "description": "Faithfulness as a golden signal: average eval score and grounded-verdict SLO ratio for claimpilot, split by prompt version, plus the eval layer's own cost. Turns red when the agent lies while everything traditional stays green."
    },
    "datasources": null,
    "variables": [],
    "panels": {
      "by_version": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Faithfulness by prompt version",
            "description": "Average score split by prompt.version — the regression concentrates on one version; the investigation's key evidence."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "gen_ai.evaluation.score.sum",
                              "temporality": "",
                              "timeAggregation": "rate",
                              "spaceAggregation": "sum",
                              "reduceTo": ""
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "service.name = 'claimpilot'"
                          },
                          "groupBy": [
                            {
                              "name": "prompt.version",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "order": null,
                          "selectFields": null,
                          "secondaryAggregations": null,
                          "functions": null,
                          "legend": ""
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "gen_ai.evaluation.score.count",
                              "temporality": "",
                              "timeAggregation": "rate",
                              "spaceAggregation": "sum",
                              "reduceTo": ""
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "service.name = 'claimpilot'"
                          },
                          "groupBy": [
                            {
                              "name": "prompt.version",
                              "signal": "",
                              "fieldContext": "attribute",
                              "fieldDataType": "string"
                            }
                          ],
                          "order": null,
                          "selectFields": null,
                          "secondaryAggregations": null,
                          "functions": null,
                          "legend": ""
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A/B",
                          "disabled": false,
                          "order": null,
                          "functions": null,
                          "legend": "{{prompt.version}}"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "links": null
        }
      },
