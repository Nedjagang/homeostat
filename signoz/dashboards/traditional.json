                          "selectFields": null,
                          "secondaryAggregations": null,
                          "functions": null,
                          "legend": "p99"
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "gen_ai.client.operation.duration.bucket",
                              "temporality": "",
                              "timeAggregation": "",
                              "spaceAggregation": "p95",
                              "reduceTo": ""
                            }
                          ],
                          "disabled": false,
                          "filter": {
                            "expression": "service.name = 'claimpilot'"
