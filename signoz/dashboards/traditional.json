{
  "schemaVersion": "v6",
  "name": "claimpilot-traditional-signals-stays-green",
  "tags": [
    {
      "key": "project",
      "value": "homeostat"
    },
    {
      "key": "service",
      "value": "claimpilot"
    },
    {
      "key": "type",
      "value": "traditional"
    }
  ],
  "spec": {
    "display": {
      "name": "ClaimPilot — Traditional Signals (stays green)",
      "description": "Latency, volume, tokens, throughput and claim errors for claimpilot. Deliberately boring: during a prompt-quality regression every panel stays green — pair with Agent Quality to see the gap faithfulness fills."
    },
    "datasources": null,
    "variables": [],
    "panels": {
      "error_rate": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "Claim error rate",
            "description": "Errored claims / all claims. Moves on infrastructure failures (broken-tool chaos), NOT on prompt-quality regressions — faithfulness is the only signal that catches those."
          },
          "plugin": {
            "kind": "signoz/TimeSeriesPanel",
            "spec": {
              "visualization": {
                "timePreference": "global_time",
                "fillSpans": false
              },
              "formatting": {
                "unit": "none",
                "decimalPrecision": "2"
              },
              "chartAppearance": {
                "lineInterpolation": "spline",
                "showPoints": false,
                "lineStyle": "solid",
                "fillMode": "none",
                "spanGaps": {
                  "fillOnlyBelow": false,
                  "fillLessThan": ""
                }
              },
              "axes": {
                "softMin": null,
                "softMax": null,
                "isLogScale": false
              },
              "legend": {
                "position": "bottom",
                "mode": "list",
                "customColors": null
              },
              "thresholds": null
            }
          },
          "queries": [
            {
              "kind": "time_series",
              "spec": {
                "plugin": {
                  "kind": "signoz/CompositeQuery",
                  "spec": {
                    "queries": [
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "A",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "claimpilot.claims.processed",
                              "temporality": "",
                              "timeAggregation": "increase",
                              "spaceAggregation": "sum",
                              "reduceTo": ""
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "service.name = 'claimpilot' AND outcome = 'error'"
                          },
                          "groupBy": null,
                          "order": null,
                          "selectFields": null,
                          "secondaryAggregations": null,
                          "functions": null,
                          "legend": ""
                        }
                      },
                      {
                        "type": "builder_query",
                        "spec": {
                          "name": "B",
                          "stepInterval": 0,
                          "signal": "metrics",
                          "source": "",
                          "aggregations": [
                            {
                              "metricName": "claimpilot.claims.processed",
                              "temporality": "",
                              "timeAggregation": "increase",
                              "spaceAggregation": "sum",
                              "reduceTo": ""
                            }
                          ],
                          "disabled": true,
                          "filter": {
                            "expression": "service.name = 'claimpilot'"
                          },
                          "groupBy": null,
                          "order": null,
                          "selectFields": null,
                          "secondaryAggregations": null,
                          "functions": null,
                          "legend": ""
                        }
                      },
                      {
                        "type": "builder_formula",
                        "spec": {
                          "name": "F1",
                          "expression": "A/B",
                          "disabled": false,
                          "order": null,
                          "functions": null,
                          "legend": "claim error rate"
                        }
                      }
                    ]
                  }
                }
              }
            }
          ],
          "links": null
        }
      },
      "latency": {
        "kind": "Panel",
        "spec": {
          "display": {
            "name": "LLM operation latency (p95 / p99)",
